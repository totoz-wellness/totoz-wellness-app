generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENHANCED TALKEASY SCHEMA WITH ANALYTICS
// ============================================

model User {
  id        String   @id @default(cuid())
  name      String
  age       Int
  email     String   @unique
  password  String
  gender    String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
  reviewedArticles Article[] @relation("ArticleReviewer")
  createdDirectories Directory[]
  talkEasyMessages TalkEasyMessage[]
  talkEasyFeedback TalkEasyFeedback[] // 🆕

  @@map("users")
}

model Article {
  id          String      @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  coverImage  String?
  videoUrl    String?
  status      ArticleStatus @default(DRAFT)
  category    String?
  tags        String[]
  readTime    Int?
  slug        String?     @unique
  
  authorId    String
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  reviewerId  String?
  reviewer    User?       @relation("ArticleReviewer", fields: [reviewerId], references: [id])
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  publishedAt DateTime?

  @@map("articles")
}

model Directory {
  id          String         @id @default(cuid())
  name        String
  type        DirectoryType
  description String
  excerpt     String?
  
  phone       String?
  email       String?
  website     String?
  
  address     String?
  city        String?
  county      String?
  region      String?
  coordinates String?
  
  operatingHours String?
  languages      String[]
  specializations String[]
  isVerified     Boolean     @default(false)
  isFeatured     Boolean     @default(false)
  
  slug        String         @unique
  tags        String[]
  
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@map("directories")
}

// 🆕 ENHANCED TALKEASY MESSAGE WITH ANALYTICS
model TalkEasyMessage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  response    String   @db.Text
  sentiment   String?
  timestamp   DateTime @default(now())
  sessionId   String?
  
  // 🆕 ANALYTICS FIELDS
  messageLength      Int?
  responseLength     Int?
  detectedTopics     String[]  @default([])
  detectedKeywords   String[]  @default([])
  emotionalIntensity String?   // LOW, MEDIUM, HIGH, CRISIS
  conversationTurn   Int?      // Message number in conversation
  processingTimeMs   Int?
  
  // 🆕 CATEGORIZATION
  primaryCategory    String?   // ANXIETY, DEPRESSION, STRESS, RELATIONSHIP, etc.
  secondaryCategory  String?
  
  // 🆕 RECOMMENDATIONS (Only when provided)
  recommendedArticles    String[]  @default([]) // Article IDs
  recommendedDirectories String[]  @default([]) // Directory IDs
  resourcesRequested     Boolean   @default(false) // Did user ask for resources?
  
  // 🆕 METADATA
  modelVersion       String?
  promptVersion      String    @default("1.0")
  
  @@index([userId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([sentiment])
  @@index([primaryCategory])
  @@index([emotionalIntensity])
  @@index([userId, sessionId])
  @@index([timestamp, primaryCategory])
  
  @@map("talkeasy_messages")
}

// 🆕 ANALYTICS AGGREGATION
model TalkEasyAnalytics {
  id              String   @id @default(cuid())
  date            DateTime @unique
  
  totalMessages   Int      @default(0)
  uniqueUsers     Int      @default(0)
  crisisCount     Int      @default(0)
  
  positiveCount   Int      @default(0)
  negativeCount   Int      @default(0)
  neutralCount    Int      @default(0)
  
  // Category and topic trends (JSON for flexibility)
  categoryBreakdown Json
  topicTrends       Json
  
  // Resource effectiveness
  articlesRecommended   Int      @default(0)
  directoriesRecommended Int     @default(0)
  
  // Performance
  avgProcessingTime Float?
  avgMessageLength  Float?
  avgResponseLength Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([date])
  @@map("talkeasy_analytics")
}

// 🆕 TRAINING DATASET (ANONYMIZED)
model TalkEasyTrainingData {
  id                String   @id @default(cuid())
  
  anonymizedMessage  String   @db.Text
  anonymizedResponse String   @db.Text
  
  sentiment         String
  primaryCategory   String
  emotionalIntensity String
  topics            String[]  @default([])
  keywords          String[]  @default([])
  
  qualityScore      Float?
  humanReviewed     Boolean  @default(false)
  includeInTraining Boolean  @default(true)
  
  originalTimestamp DateTime
  conversationTurn  Int?
  
  createdAt         DateTime @default(now())
  
  @@index([primaryCategory])
  @@index([sentiment])
  @@index([includeInTraining])
  @@index([qualityScore])
  @@map("talkeasy_training_data")
}

// 🆕 USER FEEDBACK
model TalkEasyFeedback {
  id          String   @id @default(cuid())
  userId      String
  messageId   String
  
  rating      Int      // 1-5
  helpful     Boolean?
  feedback    String?  @db.Text
  
  timestamp   DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([messageId])
  @@index([rating])
  @@map("talkeasy_feedback")
}

enum UserRole {
  USER
  CONTENT_WRITER
  CONTENT_LEAD
  SUPER_ADMIN
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum DirectoryType {
  NGO
  COUNSELOR
  HELPLINE
  SUPPORT_GROUP
  HOSPITAL
  CLINIC
  THERAPIST
  PSYCHIATRIST
  COMMUNITY_CENTER
  ONLINE_SERVICE
}